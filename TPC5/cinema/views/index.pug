extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Lista de Filmes 
    
    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th id 
          th título
          th ano
          th #gen
          th #cast
        each t in list
          tr(onclick=`window.location='/filmes/${t.id}'` style="cursor:pointer;")
            td= t.id
            td= t.title
            td= t.year
            td= t.genres.length
            td= t.cast.length
