extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1= genero.nome
    
    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          td
            b id
          td= genero.id
        tr
          td
            b nome
          td= genero.nome
        tr
          td
            b #filmes
          td= genero.numFilmes
        tr
          td
            b filmes
          td
            if genero.filmes && genero.filmes.length
              ul
                each filme in genero.filmes
                  li
                    a(href=`/filmes/${filme.id}`)= filme.title

    footer.w3-container.w3-light-grey.w3-padding-16
      a.w3-btn.w3-grey(href="/generos") Voltar atrás
