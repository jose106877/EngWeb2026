doctype html
html
  head
    title= title
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    link(rel='stylesheet', href='/stylesheets/style.css')
  body
    .w3-container.w3-teal
      h2 Cinema 
      .w3-bar
        a.w3-bar-item.w3-button(href='/filmes') Filmes
        a.w3-bar-item.w3-button(href='/atores') Atores
        a.w3-bar-item.w3-button(href='/generos') Generos
    block content
    if typeof date !== 'undefined'
      footer.w3-container.w3-teal.w3-margin-top
        h5 Generated by EngWeb2026, #{date}
