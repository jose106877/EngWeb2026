extends layout.pug

block content
  .w3-container
    .w3-card-4
      header.w3-container.w3-teal
        h3 #{ator.nome}
      .w3-container
        p
          b Id:
          |  #{ator.id}
        p
          b Numero de filmes:
          |  #{ator.numFilmes}

        h4 Filmes
        if ator.filmes && ator.filmes.length
          ul.w3-ul
            each f in ator.filmes
              li
                if f && f.id
                  a(href=`/filmes/${f.id}`)= f.title
                else
                  | #{f.title}
        else
          p Sem filmes associados.

        p
          a.w3-button.w3-teal.w3-round-large(href='/atores') Voltar aos atores