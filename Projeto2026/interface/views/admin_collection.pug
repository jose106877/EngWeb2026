extends admin_layout

block content
  .w3-container.w3-padding
    h3= page.title
    p.w3-margin-bottom= page.description

    .admin-actions.w3-margin-bottom
      a.w3-button.w3-blue.w3-small(
        href=page.addHref
      )= page.addLabel
      if page.sipExportPath
        a.w3-button.w3-white.w3-border.w3-small.w3-margin-left(
          href=page.sipExportPath
        ) Exportar
      if page.sipImportPath
        form#sipImportForm.admin-import-form.admin-actions-spacer(
          enctype='multipart/form-data'
        )
          input#sipImportInput.w3-input.w3-small.admin-import-input(
            type='file',
            name='sip',
            accept='.zip,application/zip',
            required
          )
          button.w3-button.w3-green.w3-small(type='submit') Importar

    .w3-responsive
      table.w3-table.w3-striped.w3-bordered.w3-hoverable
        thead
          tr.w3-light-grey
            each column in page.columns
              th.w3-padding-small= column
            th.w3-padding-small Operações
        tbody
          if !page.rows.length
            tr
              td.w3-padding-large.w3-center(colspan=page.columns.length + 1)= page.emptyMessage
          else
            each row in page.rows
              tr
                each cell, index in row.cells
                  td.w3-padding-small(data-label=page.columns[index])
                    case cell.type
                      when 'image'
                        img.w3-image(
                          src=cell.src,
                          alt=cell.alt,
                          class='admin-table-image'
                        )
                      when 'link'
                        a(
                          href=cell.href,
                          target='_blank',
                          rel='noopener noreferrer'
                        )= cell.label
                      when 'badge'
                        span.w3-tag.w3-light-grey= cell.value
                      default
                        = cell.value
                td.w3-padding-small(data-label='Operações')
                  a.w3-button.w3-blue.w3-small.w3-margin-right(href=row.editHref title='Editar') Editar
                  if page.sipExportPath
                    a.w3-button.w3-white.w3-border.w3-small.w3-margin-right(
                      href=`${page.sipExportPath}/${row.id}`,
                      title='Exportar'
                    ) Exportar
                  button.w3-button.w3-red.w3-small(type='button' onclick=`apagarItem('${row.id}')`) Apagar

  script.
    const adminDeletePath = !{JSON.stringify(page.deletePath)};
    const sipImportPath = !{JSON.stringify(page.sipImportPath || '')};

    async function apagarItem(id) {
      if (!confirm('Tem a certeza que quer apagar este item?')) return;

      const response = await fetch(`${adminDeletePath}?_id=${encodeURIComponent(id)}`, {
        method: 'DELETE'
      });

      if (response.status === 401) {
        try {
          const data = await response.json();
          if (data?.redirectTo) {
            window.location.href = data.redirectTo;
            return;
          }
        } catch (error) {
          // noop
        }
      }

      if (!response.ok) {
        alert('Não foi possível apagar o registo.');
        return;
      }

      location.reload();
    }

    const sipImportForm = document.getElementById('sipImportForm');
    if (sipImportForm && sipImportPath) {
      sipImportForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const input = document.getElementById('sipImportInput');
        if (!input?.files?.[0]) return;

        const data = new FormData();
        data.append('sip', input.files[0]);

        const response = await fetch(sipImportPath, {
          method: 'POST',
          body: data
        });

        if (!response.ok) {
          let message = 'Não foi possível importar.';
          try {
            const error = await response.json();
            message = error?.message || message;
          } catch (error) {
            // noop
          }
          alert(message);
          return;
        }

        location.reload();
      });
    }
