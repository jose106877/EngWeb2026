section#atividades.container.section.screen-page.reveal
  .section-head
    div
      p.teamv2-label O que fazemos
      h2.section-title
        span.title-word Atividades
      p.section-copy.activities-copy Destaques visuais no topo e feed curado localmente, com filtro por departamento.
    a.activities-see-all(
      href='https://www.instagram.com/aeeum_/'
      target='_blank'
      rel='noopener noreferrer'
    )
      | Ver Todas
      svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' aria-hidden='true')
        path(stroke-linecap='round' stroke-linejoin='round' d='M9 18l6-6-6-6')

  #activity-tabs.activities-tabs(role='tablist' aria-label='Filtrar atividades por departamento')

  #activities-highlights.activities-highlights-host
  p#activities-meta-status.activities-meta-status(aria-live='polite')

  #activities-feed.activities-feed-host
